# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*
!.env.example
!.env.production.example

# database
/data/

# exam images (user-provided, not tracked)
/exam-images/*
!/exam-images/.gitkeep

# caddy runtime logs
caddy.log
caddy.err.log

# compiled mcp
/dist/

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# k6 load test results
loadtest/results/
loadtest/*.json
loadtest/summary.html

# performance reports
perf-report.md
.claude/

# Generated code sandbox — AI-authored runtime artifacts
generated/scripts/*.ts
generated/scripts/*.js
generated/scripts/*.py
generated/queries/*.sql
generated/reports/*
generated/patches/*
!generated/README.md
