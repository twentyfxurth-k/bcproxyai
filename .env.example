# SMLGateway — ตั้งค่า API Keys
# คัดลอกไฟล์นี้เป็น .env.local แล้วใส่ key ของคุณ
#
# cp .env.example .env.local

# จำเป็น — สมัครฟรีที่ https://openrouter.ai/keys
OPENROUTER_API_KEY=sk-or-v1-xxxx

# จำเป็น — สมัครฟรีที่ https://console.groq.com/keys
GROQ_API_KEY=gsk_xxxx

# ไม่บังคับ — Kilo AI Gateway (ไม่ต้องใช้ key ก็สแกนได้)
KILO_API_KEY=

# ไม่บังคับ — สมัครฟรีที่ https://aistudio.google.com/apikey
GOOGLE_AI_API_KEY=

# ไม่บังคับ — สมัครฟรีที่ https://cloud.cerebras.ai
CEREBRAS_API_KEY=

# ไม่บังคับ — สมัครฟรีที่ https://cloud.sambanova.ai
SAMBANOVA_API_KEY=

# ไม่บังคับ — สมัครฟรีที่ https://console.mistral.ai (ต้องยืนยันเบอร์โทร)
MISTRAL_API_KEY=

# ไม่บังคับ — สมัครที่ https://platform.deepseek.com (ใช้เป็น Judge ตรวจข้อสอบ ถูกมาก)
DEEPSEEK_API_KEY=

# ไม่บังคับ — สมัครฟรีที่ https://build.nvidia.com (NIM — Llama, Nemotron, DeepSeek ~1000 req/mo)
NVIDIA_API_KEY=

# ══════ ใหม่ — Free/Cheap providers เพิ่มเติม ══════

# Chutes.ai — community GPU, ไม่จำกัดรายเดือน (https://chutes.ai/)
CHUTES_API_KEY=

# LLM7.io — gateway free 30 RPM (https://token.llm7.io/)
LLM7_API_KEY=

# Scaleway 🇪🇺 — 1M tokens free lifetime (https://console.scaleway.com/)
SCALEWAY_API_KEY=

# Pollinations AI — ไม่ต้อง key ก็ใช้ได้ (https://enter.pollinations.ai/)
POLLINATIONS_API_KEY=

# Ollama Cloud — 100 req/hr ฟรี (https://ollama.com/cloud)
OLLAMA_CLOUD_API_KEY=

# SiliconFlow 🇨🇳 — 50 RPD free (https://siliconflow.com/)
SILICONFLOW_API_KEY=

# glhf.chat — beta free, run any HF model (https://glhf.chat/)
GLHF_API_KEY=

# Together AI — $25 signup credits (https://api.together.xyz/settings/api-keys)
TOGETHER_API_KEY=

# Hyperbolic — $1 signup credits (https://app.hyperbolic.ai/signup)
HYPERBOLIC_API_KEY=

# Z.AI (Zhipu GLM) — free signup credits (https://z.ai/manage-apikey/apikey-list)
ZAI_API_KEY=

# Alibaba DashScope (Qwen) — 1M tokens ฟรี 90 วัน (https://bailian.console.alibabacloud.com/)
DASHSCOPE_API_KEY=

# Reka AI — $10 ฟรีทุกเดือน auto-refresh (https://platform.reka.ai/)
REKA_API_KEY=

# ไม่บังคับ — Ollama Local LLM (ติดตั้ง: https://ollama.com)
# ถ้า Ollama รันอยู่ที่ localhost:11434 จะ scan โมเดลอัตโนมัติ
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_API_KEY=ollama
