# ─────────────────────────────────────────────────────────────────────
# SMLGateway — Environment Variables
# ─────────────────────────────────────────────────────────────────────
# Two modes controlled by this file:
#
#   1. LOCAL (default)   — no auth, no login, OpenAI-compatible open endpoint
#                           * Leave every variable in the AUTH section blank/unset
#                           * Great for Docker Desktop + local dev
#
#   2. SERVER (public)   — Google OAuth + Bearer API keys required
#                           * Set at least AUTH_OWNER_EMAIL or GATEWAY_API_KEY
#                           * Middleware auto-switches to enforced mode
#                           * Admin can issue per-client keys via /admin/keys UI
#
# Rule of thumb: if ANY of `AUTH_OWNER_EMAIL` / `GATEWAY_API_KEY` is set,
# auth is ENABLED. Otherwise it's OFF (local mode).
#
# cp .env.example .env.local
# ─────────────────────────────────────────────────────────────────────

# ─── AUTH (leave blank for local, fill for server) ──────────────────────

# Owner email(s) — full admin access on production. Any other logged-in
# Google account becomes read-only viewer (can browse dashboard but cannot
# call /v1/* or mutate /api/*).
#
# Supports multiple admins — separate with comma, semicolon, or whitespace:
#   AUTH_OWNER_EMAIL=alice@acme.com
#   AUTH_OWNER_EMAIL=alice@acme.com,bob@acme.com,carol@acme.com
AUTH_OWNER_EMAIL=

# Master Bearer API key — used by OpenAI SDK / curl. Grants full access.
# Generate: node -e "console.log('sk-gw-' + require('crypto').randomBytes(32).toString('hex'))"
# Admin can issue additional per-client keys from /admin/keys UI; those are
# stored in `gateway_api_keys` table (SHA-256 hashed).
GATEWAY_API_KEY=

# NextAuth JWT signing secret — only needed when AUTH_OWNER_EMAIL is set.
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
NEXTAUTH_SECRET=

# Public URL (used by NextAuth for OAuth callback) — required with OAuth.
# NEXTAUTH_URL=https://your-domain.example.com

# Google OAuth client — only needed when AUTH_OWNER_EMAIL is set.
# Create at https://console.cloud.google.com/apis/credentials
# Redirect URI to add: {NEXTAUTH_URL}/api/auth/callback/google
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ─── Runtime config (always applies) ────────────────────────────────────

# Ollama local URL (if you run Ollama on the host)
OLLAMA_BASE_URL=http://host.docker.internal:11434

# Cloudflare account ID — used to construct Workers AI inference URL
# (the API token itself goes in the DB via /setup modal)
CLOUDFLARE_ACCOUNT_ID=

# Database / cache (defaults work with docker-compose; override only when
# running outside compose)
# DATABASE_URL=postgres://sml:smlpass@localhost:5434/smlgateway
# REDIS_URL=redis://localhost:6382
