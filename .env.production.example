# SMLGateway production env — copy to .env.production on the droplet.
# DO NOT commit the real .env.production file.

# === Authentication (required in production) ===
# Google OAuth client — reuse CRM client (shared with crm.satistang.com, demo001.satistang.com)
GOOGLE_CLIENT_ID=183871505957-gt3ol3ir2163dm1peqai08sp56hpqkm8.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=<set-from-google-console>

# Owner(s) — full access; any other Google account becomes read-only viewer.
# Supports multiple admins — separate with comma:
#   AUTH_OWNER_EMAIL=jaturapornchai@gmail.com,teammate@gmail.com
AUTH_OWNER_EMAIL=jaturapornchai@gmail.com

# NextAuth JWT signing secret (32 random bytes, base64)
# Regenerate with: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
NEXTAUTH_SECRET=<generate-with-node-crypto-randomBytes-32-base64>

# Public URL (used by NextAuth for callback + cookie domain)
NEXTAUTH_URL=https://smlgateway.smlsoftdemo.com

# Bearer API key for OpenAI SDK / curl access — grants the same privileges
# as the owner (full access to /v1/*). Keep secret.
GATEWAY_API_KEY=sk-gw-<generate-with-node-crypto-randomBytes-32-hex>

# === Provider keys (copy from .env.local) ===
# GROQ_API_KEY=
# GEMINI_API_KEY=
# CEREBRAS_API_KEY=
# ... etc.
