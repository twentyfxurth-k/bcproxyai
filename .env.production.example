# SMLGateway production env — copy to .env.production on the droplet.
# DO NOT commit the real .env.production file.

# === Authentication — Bearer API key only ===
# Master Bearer key. Clients send `Authorization: Bearer <key>` via OpenAI SDK.
# Generate: node -e "console.log('sk-gw-' + require('crypto').randomBytes(32).toString('hex'))"
GATEWAY_API_KEY=sk-gw-<generate-with-node-crypto-randomBytes-32-hex>

# Owner email(s) — metadata only (displayed in UI, used as created_by audit
# for admin-issued keys). Supports multiple admins:
#   AUTH_OWNER_EMAIL=jaturapornchai@gmail.com,teammate@gmail.com
AUTH_OWNER_EMAIL=jaturapornchai@gmail.com

# === Provider keys (managed from dashboard /setup, NOT env) ===
# Leave these empty. The gateway reads provider API keys from the
# `api_keys` database table populated by the Setup modal.
